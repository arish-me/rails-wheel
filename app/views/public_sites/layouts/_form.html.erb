<%= styled_form_with model: [@client, layout], class: "space-y-4" do |f| %>
  <% if layout.errors.any? %>
    <%= render "shared/form_errors" , model: layout %>
  <% end %>
  <section class="space-y-2 overflow-hidden">
    <%= f.text_field :name, label: 'Name' , placeholder: 'Enter Name' %>
    <%= f.rich_text_area :content %>
  </section>
  <section>
    <%= f.submit 'Submit' %>
  </section>
<% end %>